{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "The Great Trading Company",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "The Great Trading Co.${{APP_NAME_SUFFIX}}",
        "full": "The Great Trading Company — LOB MCP Apps"
    },
    "description": {
        "short": "Manage Salesforce CRM and ServiceNow ITSM from one command post",
        "full": "A unified MCP Apps agent that connects to Salesforce (Leads, Opportunities) and ServiceNow (Incidents, Requests) — rendering interactive widgets directly in M365 Copilot chat with full CRUD capability."
    },
    "accentColor": "#C9A84C",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
