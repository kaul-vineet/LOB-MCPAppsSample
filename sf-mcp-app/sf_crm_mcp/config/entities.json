{
  "Lead": {
    "soqlObject": "Lead",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "FirstName",  "key": "first_name",  "label": "First Name", "width": "150px" },
      { "apiName": "LastName",   "key": "last_name",   "label": "Last Name",  "width": "150px" },
      { "apiName": "Company",    "key": "company",     "label": "Company",    "width": "180px" },
      { "apiName": "Email",      "key": "email",       "label": "Email",      "width": "200px" },
      { "apiName": "Phone",      "key": "phone",       "label": "Phone",      "width": "140px" },
      { "apiName": "Status",     "key": "status",      "label": "Status",     "width": "160px" },
      { "apiName": "LeadSource", "key": "lead_source", "label": "Source",     "width": "130px" }
    ],
    "hiddenColumns": [
      { "apiName": "IsConverted",               "key": "is_converted" },
      { "apiName": "ConvertedAccount.Name",     "key": "converted_account_name" },
      { "apiName": "ConvertedOpportunity.Name", "key": "converted_opportunity_name" }
    ],
    "form": [
      { "apiName": "FirstName",  "label": "First Name",  "required": false },
      { "apiName": "LastName",   "label": "Last Name",   "required": true  },
      { "apiName": "Company",    "label": "Company",     "required": true  },
      { "apiName": "Email",      "label": "Email",       "required": false },
      { "apiName": "Phone",      "label": "Phone",       "required": false },
      { "apiName": "Status",     "label": "Status",      "required": false },
      { "apiName": "LeadSource", "label": "Lead Source", "required": false }
    ],
    "statusColors": {
      "Open - Not Contacted": {
        "light": { "bg": "#EEF4FF", "color": "#0176D3" },
        "dark":  { "bg": "#0b3573", "color": "#8dc7ff" }
      },
      "Working - Contacted": {
        "light": { "bg": "#FEF0CD", "color": "#A07000" },
        "dark":  { "bg": "#5c3b0a", "color": "#ffd970" }
      },
      "Closed - Converted": {
        "light": { "bg": "#EBF7E6", "color": "#2E844A" },
        "dark":  { "bg": "#1a3a2a", "color": "#7cd992" }
      },
      "Closed - Not Converted": {
        "light": { "bg": "#FEE5E5", "color": "#BA0517" },
        "dark":  { "bg": "#3a1a1a", "color": "#ff9a9a" }
      }
    }
  },
  "Opportunity": {
    "soqlObject": "Opportunity",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "Name",        "key": "name",        "label": "Name",        "width": "200px" },
      { "apiName": "Account.Name","key": "account_name","label": "Account",     "width": "180px" },
      { "apiName": "StageName",   "key": "stage",       "label": "Stage",       "width": "160px" },
      { "apiName": "Amount",      "key": "amount",      "label": "Amount",      "width": "120px" },
      { "apiName": "CloseDate",   "key": "close_date",  "label": "Close Date",  "width": "120px" },
      { "apiName": "Probability", "key": "probability", "label": "Probability", "width": "100px" }
    ],
    "hiddenColumns": [
      { "apiName": "AccountId", "key": "account_id" }
    ],
    "form": [
      { "apiName": "Name",      "label": "Opportunity Name", "required": true  },
      { "apiName": "StageName", "label": "Stage",            "required": true  },
      { "apiName": "Amount",    "label": "Amount",           "required": false },
      { "apiName": "CloseDate", "label": "Close Date",       "required": false }
    ],
    "statusColors": {
      "Closed Won":  { "light": { "bg": "#EBF7E6", "color": "#2E844A" }, "dark": { "bg": "#1a3a2a", "color": "#7cd992" } },
      "Closed Lost": { "light": { "bg": "#FEE5E5", "color": "#BA0517" }, "dark": { "bg": "#3a1a1a", "color": "#ff9a9a" } },
      "Prospecting": { "light": { "bg": "#EEF4FF", "color": "#0176D3" }, "dark": { "bg": "#0b3573", "color": "#8dc7ff" } }
    }
  },
  "Account": {
    "soqlObject": "Account",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "Name",              "key": "name",                "label": "Name",      "width": "200px" },
      { "apiName": "Industry",          "key": "industry",            "label": "Industry",  "width": "150px" },
      { "apiName": "Phone",             "key": "phone",               "label": "Phone",     "width": "140px" },
      { "apiName": "Website",           "key": "website",             "label": "Website",   "width": "180px" },
      { "apiName": "BillingCity",       "key": "billing_city",        "label": "City",      "width": "130px" },
      { "apiName": "Type",              "key": "type",                "label": "Type",      "width": "120px" },
      { "apiName": "NumberOfEmployees", "key": "number_of_employees", "label": "Employees", "width": "100px" }
    ],
    "hiddenColumns": [],
    "form": [
      { "apiName": "Name",     "label": "Account Name", "required": true  },
      { "apiName": "Industry", "label": "Industry",     "required": false },
      { "apiName": "Phone",    "label": "Phone",        "required": false },
      { "apiName": "Website",  "label": "Website",      "required": false }
    ],
    "statusColors": {}
  },
  "Contact": {
    "soqlObject": "Contact",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "FirstName",   "key": "first_name",   "label": "First Name", "width": "140px" },
      { "apiName": "LastName",    "key": "last_name",    "label": "Last Name",  "width": "140px" },
      { "apiName": "Email",       "key": "email",        "label": "Email",      "width": "200px" },
      { "apiName": "Phone",       "key": "phone",        "label": "Phone",      "width": "140px" },
      { "apiName": "Title",       "key": "title",        "label": "Title",      "width": "150px" },
      { "apiName": "Account.Name","key": "account_name", "label": "Account",    "width": "170px" }
    ],
    "hiddenColumns": [
      { "apiName": "AccountId", "key": "account_id" }
    ],
    "form": [
      { "apiName": "FirstName", "label": "First Name", "required": false },
      { "apiName": "LastName",  "label": "Last Name",  "required": true  },
      { "apiName": "Email",     "label": "Email",      "required": false },
      { "apiName": "Phone",     "label": "Phone",      "required": false },
      { "apiName": "Title",     "label": "Title",      "required": false }
    ],
    "statusColors": {}
  },
  "Case": {
    "soqlObject": "Case",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "CaseNumber",   "key": "case_number",   "label": "Case #",   "width": "110px" },
      { "apiName": "Subject",      "key": "subject",       "label": "Subject",  "width": "220px" },
      { "apiName": "Status",       "key": "status",        "label": "Status",   "width": "130px" },
      { "apiName": "Priority",     "key": "priority",      "label": "Priority", "width": "110px" },
      { "apiName": "Account.Name", "key": "account_name",  "label": "Account",  "width": "160px" }
    ],
    "hiddenColumns": [
      { "apiName": "CreatedDate", "key": "created_date" },
      { "apiName": "AccountId",   "key": "account_id"   }
    ],
    "form": [
      { "apiName": "Subject",     "label": "Subject",     "required": true  },
      { "apiName": "Priority",    "label": "Priority",    "required": false },
      { "apiName": "Description", "label": "Description", "required": false }
    ],
    "statusColors": {
      "New":      { "light": { "bg": "#EEF4FF", "color": "#0176D3" }, "dark": { "bg": "#0b3573", "color": "#8dc7ff" } },
      "Open":     { "light": { "bg": "#FEF0CD", "color": "#A07000" }, "dark": { "bg": "#5c3b0a", "color": "#ffd970" } },
      "Closed":   { "light": { "bg": "#EBF7E6", "color": "#2E844A" }, "dark": { "bg": "#1a3a2a", "color": "#7cd992" } },
      "Escalated":{ "light": { "bg": "#FEE5E5", "color": "#BA0517" }, "dark": { "bg": "#3a1a1a", "color": "#ff9a9a" } }
    }
  },
  "Task": {
    "soqlObject": "Task",
    "orderBy": "CreatedDate DESC",
    "limit": 5,
    "columns": [
      { "apiName": "Subject",      "key": "subject",       "label": "Subject",    "width": "220px" },
      { "apiName": "Status",       "key": "status",        "label": "Status",     "width": "130px" },
      { "apiName": "Priority",     "key": "priority",      "label": "Priority",   "width": "110px" },
      { "apiName": "ActivityDate", "key": "activity_date", "label": "Due Date",   "width": "120px" },
      { "apiName": "WhoId",        "key": "who_id",        "label": "Who",        "width": "140px" },
      { "apiName": "WhatId",       "key": "what_id",       "label": "Related To", "width": "140px" }
    ],
    "hiddenColumns": [],
    "form": [
      { "apiName": "Subject",      "label": "Subject",  "required": true  },
