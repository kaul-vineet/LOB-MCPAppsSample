    "statusColors": {
      "Not Started":  { "light": { "bg": "#EEF4FF", "color": "#0176D3" }, "dark": { "bg": "#0b3573", "color": "#8dc7ff" } },
      "In Progress":  { "light": { "bg": "#FEF0CD", "color": "#A07000" }, "dark": { "bg": "#5c3b0a", "color": "#ffd970" } },
      "Completed":    { "light": { "bg": "#EBF7E6", "color": "#2E844A" }, "dark": { "bg": "#1a3a2a", "color": "#7cd992" } },
      "Deferred":     { "light": { "bg": "#F3F3F3", "color": "#706E6B" }, "dark": { "bg": "#2b2b2b", "color": "#c0bfbd" } }
    }
