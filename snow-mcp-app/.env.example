# ── ServiceNow Connection ──────────────────────────────────────────────────────
SERVICENOW_INSTANCE=dev12345
SERVICENOW_AUTH_MODE=oauth

# OAuth 2.0 Client Credentials (when AUTH_MODE=oauth)
SERVICENOW_CLIENT_ID=your-client-id
SERVICENOW_CLIENT_SECRET=your-client-secret

# Basic Auth fallback (when AUTH_MODE=basic)
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=*

# App Insights telemetry (optional — leave blank to disable)
APPINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_ROLE_NAME=lob-mcp
